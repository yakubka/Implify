# Скопируй в .env и подставь значения (.env в .gitignore)

# --- PostgreSQL ---
POSTGRES_DB=implify
POSTGRES_USER=implify
POSTGRES_PASSWORD=change_me_local

# --- Java core ---
JWT_SECRET=change_me_at_least_32_bytes_long_secret_key
JWT_EXPIRATION_MS=86400000

# --- Python matching ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Kafka (Redpanda) ---
KAFKA_BOOTSTRAP=redpanda:9092
